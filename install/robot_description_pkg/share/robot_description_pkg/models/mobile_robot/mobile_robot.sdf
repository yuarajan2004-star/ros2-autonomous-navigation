<sdf version="1.11">
  <model name="mobile_robot">

    <link name="base_link">

      <pose>0 0 0.10 0 0 0</pose>

      <inertial>
        <mass>10.4</mass>
        <inertia>
          <ixx>0.1073</ixx>
          <iyy>0.1136</iyy>
          <izz>0.1065</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.40 0.30 0.15</size>
          </box>
        </geometry>
      </collision>

      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.40 0.30 0.15</size>
          </box>
        </geometry>
      </visual>

      <!-- LIDAR -->

      <sensor name="lidar_sensor" type="gpu_lidar">

        <pose>0.15 0 0.12 0 0 0</pose>

        <always_on>true</always_on>

        <update_rate>10</update_rate>

        <visualize>true</visualize>

        <topic>/scan</topic>

        <frame_id>laser_frame</frame_id>

        <ray>

          <scan>

            <horizontal>

              <samples>720</samples>

              <resolution>1</resolution>

              <min_angle>-3.14159</min_angle>

              <max_angle>3.14159</max_angle>

            </horizontal>

          </scan>

          <range>

            <min>0.10</min>

            <max>20.0</max>

            <resolution>0.01</resolution>

          </range>

        </ray>

      </sensor>

      <!-- CAMERA -->

      <sensor name="camera_sensor" type="camera">

        <pose>0.10 0 0.15 0 0 0</pose>

        <always_on>true</always_on>

        <update_rate>30</update_rate>

        <visualize>true</visualize>

        <topic>/camera/image_raw</topic>

        <camera>

          <horizontal_fov>1.5708</horizontal_fov>

          <image>

            <width>640</width>

            <height>480</height>

            <format>R8G8B8</format>

          </image>

          <clip>

            <near>0.1</near>

            <far>100</far>

          </clip>

        </camera>

      </sensor>

      <!-- IMU -->

      <sensor name="imu_sensor" type="imu">

        <pose>0 0 0 0 0 0</pose>

        <always_on>true</always_on>

        <update_rate>100</update_rate>

        <topic>/imu</topic>

      </sensor>

    </link>

    <!-- LEFT WHEEL -->

    <joint name="left_wheel_joint" type="revolute">

      <pose relative_to="base_link">0 0.15 -0.05 0 0 0</pose>

      <parent>base_link</parent>

      <child>left_wheel</child>

      <axis>

        <xyz>0 1 0</xyz>

        <limit>

          <lower>-1000000</lower>

          <upper>1000000</upper>

        </limit>

      </axis>

    </joint>

    <link name="left_wheel">

      <inertial>

        <mass>0.5</mass>

        <inertia>

          <ixx>0.001</ixx>

          <iyy>0.001</iyy>

          <izz>0.001</izz>

          <ixy>0</ixy>

          <ixz>0</ixz>

          <iyz>0</iyz>

        </inertia>

      </inertial>

      <collision name="left_wheel_collision">

        <pose>0 0 0 1.5708 0 0</pose>

        <geometry>

          <cylinder>

            <radius>0.05</radius>

            <length>0.03</length>

          </cylinder>

        </geometry>

      </collision>

      <visual name="left_wheel_visual">

        <pose>0 0 0 1.5708 0 0</pose>

        <geometry>

          <cylinder>

            <radius>0.05</radius>

            <length>0.03</length>

          </cylinder>

        </geometry>

      </visual>

    </link>

    <!-- RIGHT WHEEL -->

    <joint name="right_wheel_joint" type="revolute">

      <pose relative_to="base_link">0 -0.15 -0.05 0 0 0</pose>

      <parent>base_link</parent>

      <child>right_wheel</child>

      <axis>

        <xyz>0 1 0</xyz>

        <limit>

          <lower>-1000000</lower>

          <upper>1000000</upper>

        </limit>

      </axis>

    </joint>

    <link name="right_wheel">

      <inertial>

        <mass>0.5</mass>

        <inertia>

          <ixx>0.001</ixx>

          <iyy>0.001</iyy>

          <izz>0.001</izz>

          <ixy>0</ixy>

          <ixz>0</ixz>

          <iyz>0</iyz>

        </inertia>

      </inertial>

      <collision name="right_wheel_collision">

        <pose>0 0 0 1.5708 0 0</pose>

        <geometry>

          <cylinder>

            <radius>0.05</radius>

            <length>0.03</length>

          </cylinder>

        </geometry>

      </collision>

      <visual name="right_wheel_visual">

        <pose>0 0 0 1.5708 0 0</pose>

        <geometry>

          <cylinder>

            <radius>0.05</radius>

            <length>0.03</length>

          </cylinder>

        </geometry>

      </visual>

    </link>

    <!-- FRAMES -->

    <frame name="camera_joint" attached_to="base_link">
      <pose>0.10 0 0.15 0 0 0</pose>
    </frame>

    <frame name="camera_link" attached_to="camera_joint">
      <pose>0 0 0 0 0 0</pose>
    </frame>

    <frame name="camera_optical_joint" attached_to="camera_link">
      <pose>0 0 0 -1.5708 0 -1.5708</pose>
    </frame>

    <frame name="camera_optical_frame" attached_to="camera_optical_joint">
      <pose>0 0 0 0 0 0</pose>
    </frame>

    <frame name="lidar_joint" attached_to="base_link">
      <pose>0.15 0 0.12 0 0 0</pose>
    </frame>

    <frame name="lidar_link" attached_to="lidar_joint">
      <pose>0 0 0 0 0 0</pose>
    </frame>

    <frame name="laser_joint" attached_to="lidar_link">
      <pose>0 0 0 0 0 0</pose>
    </frame>

    <frame name="laser_frame" attached_to="laser_joint">
      <pose>0 0 0 0 0 0</pose>
    </frame>

    <!-- DIFF DRIVE -->

    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">

      <left_joint>left_wheel_joint</left_joint>

      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.30</wheel_separation>

      <wheel_radius>0.05</wheel_radius>

      <topic>cmd_vel</topic>

      <odom_topic>/odom</odom_topic>

      <tf_topic>/tf</tf_topic>

      <frame_id>odom</frame_id>

      <child_frame_id>base_link</child_frame_id>

      <odom_publish_frequency>30</odom_publish_frequency>

    </plugin>

  </model>
</sdf>
