<?xml version="1.0"?>

<robot name="mobile_robot">

  <!-- ========================= -->
  <!-- Base Link -->
  <!-- ========================= -->

  <link name="base_link">

    <visual>
      <geometry>
        <box size="0.4 0.3 0.15"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <box size="0.4 0.3 0.15"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="10.0"/>
      <inertia
          ixx="0.10"
          ixy="0.0"
          ixz="0.0"
          iyy="0.10"
          iyz="0.0"
          izz="0.10"/>
    </inertial>

  </link>

  <!-- ========================= -->
  <!-- Left Wheel -->
  <!-- ========================= -->

  <link name="left_wheel">

    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia
          ixx="0.001"
          ixy="0.0"
          ixz="0.0"
          iyy="0.001"
          iyz="0.0"
          izz="0.001"/>
    </inertial>

  </link>

  <joint name="left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.15 -0.05"/>
  </joint>

  <!-- ========================= -->
  <!-- Right Wheel -->
  <!-- ========================= -->

  <link name="right_wheel">

    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia
          ixx="0.001"
          ixy="0.0"
          ixz="0.0"
          iyy="0.001"
          iyz="0.0"
          izz="0.001"/>
    </inertial>

  </link>

  <joint name="right_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.15 -0.05"/>
  </joint>

  <!-- ========================= -->
  <!-- LiDAR -->
  <!-- ========================= -->

  <link name="lidar_link">

    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia
          ixx="0.0001"
          ixy="0.0"
          ixz="0.0"
          iyy="0.0001"
          iyz="0.0"
          izz="0.0001"/>
    </inertial>

  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.15 0 0.12"/>
  </joint>

  <link name="laser_frame"/>

  <joint name="laser_joint" type="fixed">
    <parent link="lidar_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Camera -->
  <!-- ========================= -->

  <link name="camera_link">

    <visual>
      <geometry>
        <box size="0.06 0.06 0.04"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <box size="0.06 0.06 0.04"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia
          ixx="0.0001"
          ixy="0.0"
          ixz="0.0"
          iyy="0.0001"
          iyz="0.0"
          izz="0.0001"/>
    </inertial>

  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.10 0 0.15"/>
  </joint>

  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

</robot>
