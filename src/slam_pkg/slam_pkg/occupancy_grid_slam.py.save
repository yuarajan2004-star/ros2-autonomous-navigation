#!/usr/bin/env python3

import math

import rclpy
from rclpy.node import Node

from sensor_msgs.msg import LaserScan
from nav_msgs.msg import OccupancyGrid


class OccupancyGridSLAM(Node):

    def __init__(self):

        super().__init__('occupancy_grid_slam')

        self.map_pub = self.create_publisher(
            OccupancyGrid,
            '/slam_map',
            10
        )

        self.scan_sub = self.create_subscription(
            LaserScan,
            '/scan',
            self.scan_callback,
            10
        )

        self.width = 200
        self.height = 200
        self.resolution = 0.05

        self.get_logger().info(
            'Occupancy Grid SLAM started'
        )

    def scan_callback(self, scan):

        grid = OccupancyGrid()

        grid.header.stamp = self.get_clock().now().to_msg()
        grid.header.frame_id = "base_link"

        grid.info.resolution = self.resolution
        grid.info.width = self.width
        grid.info.height = self.height

        grid.info.origin.position.x = -5.0
        grid.info.origin.position.y = -5.0
        grid.info.origin.position.z = 0.0

        data = [-1] * (self.width * self.height)

        occupied_count = 0

        angle = scan.angle_min

        for r in scan.ranges:

            if math.isfinite(r):

                x = r * math.cos(angle)
                y = r * math.sin(angle)

                gx = int((x + 5.0) / self.resolution)
                gy = int((y + 5.0) / self.resolution)

                if (
                    0 <= gx < self.width and
                    0 <= gy < self.height
                ):

                    index = gy * self.width + gx

                    data[index] = 100

                    occupied_count += 1

            angle += scan.angle_increment

        self.get_logger().info(
            f'Occupied cells: {occupied_count}'
        )

        grid.data = data

        self.map_pub.publish(grid)


def main(args=None):

    rclpy.init(args=args)

    node = OccupancyGridSLAM()

    rclpy.spin(node)

    node.destroy_node()

    rclpy.shutdown()


if __name__ == '__main__':

